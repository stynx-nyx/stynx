{
  "name": "stynx-workspace",
  "private": true,
  "version": "0.2.0",
  "license": "MIT",
  "description": "STYNX monorepo foundation for backend, frontend, apps, and tooling",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=9 <10"
  },
  "scripts": {
    "build": "turbo run build --filter='./packages/*' --filter='./packages-web/*' --filter='./tools/*' --filter='./test/*' --filter=docs",
    "lint": "turbo run lint --filter='./packages/*' --filter='./packages-web/*' --filter='./tools/*' --filter='./test/*'",
    "typecheck": "turbo run typecheck --filter='./packages/*' --filter='./packages-web/*' --filter='./tools/*' --filter=docs",
    "test": "turbo run test --filter='./packages/*' --filter='./packages-web/*' --filter='./tools/*' --filter='./test/*'",
    "test:int": "turbo run test:int --filter='./packages/*'",
    "check:engines": "node scripts/check-engines.mjs",
    "lint:deadcode": "knip --config tools/repo-config/knip.config.ts --no-config-hints",
    "lint:deps": "depcheck --ignore-patterns='**/*.test.ts,**/*.spec.ts' --skip-missing --ignores='@commitlint/cli,@commitlint/config-conventional,@stryker-mutator/jest-runner,@stryker-mutator/typescript-checker,eslint-plugin-boundaries,eslint-plugin-jsdoc,prettier'",
    "lint:migrations": "pnpm --filter migration-linter run lint:repo",
    "lint:cycles": "madge --circular packages/ packages-web/ tools/ --extensions ts,mjs --exclude '(^|/)(dist|build|coverage|node_modules)/'",
    "lint:workflows": "github-actionlint .github/workflows/*.yml",
    "db:verify": "node scripts/db-verify.mjs",
    "ci:stynx": "pnpm check:engines && pnpm lint && pnpm lint:deadcode && pnpm lint:deps && pnpm lint:cycles && pnpm typecheck && pnpm test && pnpm test:int && pnpm build && pnpm run doctor",
    "ci:stynx:release": "pnpm release:policy && pnpm release:drafts",
    "ci:reference-apps": "pnpm --filter @stynx/reference-api build && pnpm --filter @stynx/reference-api test && pnpm --filter @stynx/reference-api test:int && pnpm --filter @stynx/reference-web build && pnpm --filter @stynx/reference-web build:web",
    "ci:local": "bash scripts/ci-local/run.sh",
    "evidence:collect": "node scripts/evidence/collect-local-evidence.mjs",
    "evidence:verify": "node scripts/evidence/verify-local-evidence.mjs --mode strict",
    "evidence:hash": "node scripts/evidence/source-hash.mjs",
    "clean": "node scripts/clean-workspace.mjs",
    "clean:dry": "node scripts/clean-workspace.mjs --dry-run",
    "changeset": "changeset",
    "release:status": "changeset status --output .changeset/status.json",
    "release:drafts": "pnpm release:status && node scripts/generate-release-drafts.mjs",
    "release:policy": "node scripts/verify-release-policy.mjs",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "release:publish:ci": "node scripts/changesets-publish-ci.mjs",
    "doctor": "node scripts/stynx-doctor.mjs",
    "test:mutation": "pnpm --filter @stynx/auth stryker && pnpm --filter @stynx/tenancy stryker && pnpm --filter @stynx/data stryker",
    "check:rls-smoke": "bash scripts/check-rls-smoke.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "depcheck": "^1.4.7",
    "eslint": "^10.3.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "github-actionlint": "1.7.12",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "knip": "^6.7.0",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.8",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx,cts,mts}": [
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,md,yml,yaml,scss,html}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "singleQuote": true,
    "trailingComma": "all",
    "semi": true
  },
  "pnpm": {
    "overrides": {
      "@types/node": "25.6.0",
      "dockerode": "5.0.0",
      "handlebars": "4.7.9",
      "postcss": "8.5.12",
      "serialize-javascript": "7.0.5",
      "uuid": "14.0.0",
      "webpackbar": "7.0.0"
    }
  }
}
