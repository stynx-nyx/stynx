{
  "name": "stynx-workspace",
  "private": true,
  "version": "0.2.0",
  "license": "MIT",
  "description": "STYNX monorepo foundation for backend, frontend, apps, and tooling",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20 <23",
    "pnpm": ">=9 <10"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test && pnpm test:unit",
    "test:unit": "pnpm --dir test/packages test && pnpm --dir test/backend test && pnpm --dir frontend test:unit && pnpm --dir test/scripts test",
    "test:unit:cov": "pnpm --dir test/packages exec jest --config ./jest.config.cjs --coverage --coverageDirectory ./coverage && pnpm --dir test/backend exec jest --config ./jest.config.ts --coverage --coverageDirectory ./coverage && pnpm --dir frontend exec jest --config ../test/frontend/jest.config.cjs --coverage --coverageDirectory ../test/frontend/coverage && pnpm --dir test/scripts test",
    "test:int": "turbo run test:int && pnpm --dir test/db test",
    "test:int:cov": "pnpm --dir test/db exec jest --config ./jest.config.ts --coverage --coverageDirectory ./coverage",
    "test:e2e": "turbo run test:e2e && pnpm --dir frontend test:e2e",
    "clean": "turbo run clean --continue",
    "changeset": "changeset",
    "release:status": "changeset status --output .changeset/status.json",
    "release:drafts": "pnpm release:status && node scripts/generate-release-drafts.mjs",
    "release:policy": "node scripts/verify-release-policy.mjs",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "doctor": "node scripts/stynx-doctor.mjs",
    "docs:build": "pnpm --filter docs build",
    "test:mutation": "pnpm --filter @stynx/auth stryker && pnpm --filter @stynx/tenancy stryker && pnpm --filter @stynx/data stryker",
    "check:rls-smoke": "bash scripts/check-rls-smoke.sh",
    "bootstrap:cli": "pnpm --dir bootstrap run cli --",
    "bootstrap:typecheck": "pnpm --dir bootstrap run build",
    "test:db": "pnpm --dir test/db test",
    "test:packages": "pnpm --dir test/packages test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@types/node": "^22.19.17",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "turbo": "^2.5.6",
    "typescript": "^5.9.3",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.39.1",
    "eslint-plugin-boundaries": "^5.1.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0",
    "prettier": "^3.6.2"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx,cts,mts}": [
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,md,yml,yaml,scss,html}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "handlebars": "4.7.9",
      "serialize-javascript": "7.0.5",
      "webpackbar": "7.0.0"
    }
  }
}
