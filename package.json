{
  "name": "stynx-workspace",
  "private": true,
  "version": "0.2.0",
  "license": "MIT",
  "description": "STYNX monorepo foundation for backend, frontend, apps, and tooling",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=9 <10"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test",
    "test:unit:cov": "turbo run test",
    "test:int": "turbo run test:int",
    "test:int:cov": "turbo run test:int",
    "test:e2e": "turbo run test:e2e",
    "check:engines": "node scripts/check-engines.mjs",
    "lint:deadcode": "knip --no-config-hints",
    "lint:deps": "depcheck --ignore-patterns='**/*.test.ts,**/*.spec.ts' --skip-missing --ignores='@commitlint/cli,@commitlint/config-conventional,@stryker-mutator/jest-runner,@stryker-mutator/typescript-checker,eslint-plugin-boundaries,eslint-plugin-jsdoc,prettier'",
    "lint:migrations": "pnpm --filter migration-linter run lint:repo",
    "lint:cycles": "madge --circular packages/ packages-web/ apps/ --extensions ts --exclude '(^|/)(dist|build|coverage|node_modules)/'",
    "db:verify": "node scripts/db-verify.mjs",
    "smoke:local": "bash scripts/smoke-local.sh",
    "ci:local": "bash scripts/ci-local/run.sh",
    "ci:local:browser": "bash scripts/ci-local/run.sh browser",
    "ci:local:all-linux": "bash scripts/ci-local/run.sh all-linux",
    "clean": "turbo run clean --continue",
    "changeset": "changeset",
    "release:status": "changeset status --output .changeset/status.json",
    "release:drafts": "pnpm release:status && node scripts/generate-release-drafts.mjs",
    "release:policy": "node scripts/verify-release-policy.mjs",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "doctor": "node scripts/stynx-doctor.mjs",
    "docs:build": "pnpm --filter docs build",
    "test:mutation": "pnpm --filter @stynx/auth stryker && pnpm --filter @stynx/tenancy stryker && pnpm --filter @stynx/data stryker",
    "check:rls-smoke": "bash scripts/check-rls-smoke.sh",
    "test:db": "turbo run test:int --filter @stynx/data",
    "test:packages": "turbo run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.2.1",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "knip": "^6.7.0",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx,cts,mts}": [
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,md,yml,yaml,scss,html}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@types/node": "25.6.0",
      "dockerode": "5.0.0",
      "handlebars": "4.7.9",
      "postcss": "8.5.12",
      "serialize-javascript": "7.0.5",
      "uuid": "14.0.0",
      "webpackbar": "7.0.0"
    }
  }
}
