{
  "name": "@stynx/reference-api",
  "private": true,
  "version": "0.3.0",
  "description": "Reference API app exercising the STYNX backend package family",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "start": "node dist/apps/reference-api/src/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/nest.mjs \"src/**/*.ts\"",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./jest.config.cjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@stynx/audit": "workspace:*",
    "@stynx/auth": "workspace:*",
    "@stynx/core": "workspace:*",
    "@stynx/data": "workspace:*",
    "@stynx/health": "workspace:*",
    "@stynx/idempotency": "workspace:*",
    "@stynx/logging": "workspace:*",
    "@stynx/ratelimit": "workspace:*",
    "@stynx/sessions": "workspace:*",
    "@stynx/storage": "workspace:*",
    "@stynx/tenancy": "workspace:*",
    "@stech/stynx-backend": "workspace:*",
    "drizzle-orm": "^0.44.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.937.0",
    "@nestjs/testing": "^11.1.19",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.15.6",
    "jest": "^30.3.0",
    "pg": "^8.16.3",
    "supertest": "^7.1.4",
    "testcontainers": "^11.7.2",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.3"
  }
}
