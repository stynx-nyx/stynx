# ------------------------
# Global ignores
# ------------------------
# OS junk
.DS_Store
Thumbs.db

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.turbo/

# Env files
.env
.env.*.local
backend/.env
frontend/.env

# IDE/editor
.vscode/
.idea/
*.swp

# Coverage reports
coverage/
coverage-vitest/
lcov-report/

# Temporary dirs
*/tmp
.tmp-tsconfig-smoke/
.toolchain/
.agent/
.claude/

# ------------------------
# Backend (NestJS)
# ------------------------
backend/node_modules/
backend/dist/
backend/build/
backend/tsconfig.tsbuildinfo
backend/*.tgz

# ------------------------
# Frontend (Angular)
# ------------------------
frontend/node_modules/
frontend/dist/
frontend/.angular/cache/
frontend/tsconfig.tsbuildinfo
frontend/src/environments/*.ts
!frontend/src/environments/environment*.example.ts

# ------------------------
# Root level
# ------------------------
node_modules/
dist/
build/
*.tgz
*.tmp

# Monorepo build output
apps/*/dist/
apps/*/build/
packages/*/dist/
packages/*/build/
packages-web/*/dist/
packages-web/*/build/

# Python tooling
.venv/
__pycache__/
*.pyc

# Terraform local files
.terraform/
*.tfstate
*.tfstate.*
crash.log

# CDK synthesis output
infra/cdk/cdk.out/

# Documentation build output
docs/dist/
!docs/dist/.gitkeep
docs/site/build/
docs/site/.docusaurus/
docs/site/.generated/

# Docusaurus publish state (local-only baseline tracking)
.devai/state/docs-publish-baseline.txt

# Test artefacts
.test-results/
test-results/
tests/e2e/.summary.txt
test/perf/k6/results/
test/perf/k6/baseline/
*.stryker-tmp/
reports/
docs/work/

# Generated release evidence
/.release/
/.changeset/status.json

# DEVAI per-task git worktrees (created by `devai loop-run`).
# Real git worktrees rooted at .devai/worktrees/WT-TASK-*/; the
# branches themselves are tracked, just not the checked-out trees.
/.devai/worktrees/
stryker-setup-*.js
