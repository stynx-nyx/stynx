# ------------------------
# Global ignores
# ------------------------
# OS junk
.DS_Store
Thumbs.db

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.turbo/

# Env files
.env
.env.*.local
backend/.env
frontend/.env

# IDE/editor
.vscode/
.idea/
*.swp

# Coverage reports
coverage/
lcov-report/

# Temporary dirs
*/tmp
.tmp-tsconfig-smoke/
.toolchain/

# ------------------------
# Backend (NestJS)
# ------------------------
backend/node_modules/
backend/dist/
backend/build/
backend/tsconfig.tsbuildinfo
backend/*.tgz

# ------------------------
# Frontend (Angular)
# ------------------------
frontend/node_modules/
frontend/dist/
frontend/.angular/cache/
frontend/tsconfig.tsbuildinfo
frontend/src/environments/*.ts
!frontend/src/environments/environment*.example.ts

# ------------------------
# Root level
# ------------------------
node_modules/
dist/
build/
*.tgz
*.tmp

# Monorepo build output
apps/*/dist/
apps/*/build/
packages/*/dist/
packages/*/build/
packages-web/*/dist/
packages-web/*/build/

# Python tooling
.venv/
__pycache__/
*.pyc

# Terraform local files
.terraform/
*.tfstate
*.tfstate.*
crash.log

# CDK synthesis output
infra/cdk/cdk.out/

# Documentation build output
docs/dist/
!docs/dist/.gitkeep
docs/build/
docs/.docusaurus/
docs/.generated/

# Test artefacts
test-results/
tests/e2e/.summary.txt
perf/k6/results/
*.stryker-tmp/
reports/
docs/work/inv/*
docs/work/diag/*
docs/work/plan/*
!docs/work/inv/.gitkeep
!docs/work/diag/.gitkeep
!docs/work/plan/.gitkeep
