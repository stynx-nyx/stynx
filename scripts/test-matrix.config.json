{
  "thresholds": {
    "lines": 100,
    "statements": 100,
    "branches": 100,
    "functions": 100
  },
  "policies": {
    "coverage": {
      "default": { "lines": 85, "branches": 80, "functions": 85, "statements": 85 },
      "strict": { "lines": 95, "branches": 95, "functions": 95, "statements": 95 },
      "complete": {
        "lines": 100,
        "branches": 100,
        "functions": 100,
        "statements": 100,
        "branchesTolerance": 0
      },
      "off": { "lines": 0, "branches": 0, "functions": 0, "statements": 0 }
    },
    "mutation": {
      "default": 60,
      "strict": 80,
      "strictest": 85,
      "tier1": { "break": 90, "high": 90, "low": 80 },
      "tier2": { "break": 90, "high": 95, "low": 85 },
      "tier3": { "break": 90, "high": 100, "low": 90 }
    },
    "perf": {
      "default": {
        "p50_ms": 5000,
        "p95_ms": 9000,
        "rps_min": 0.2
      }
    }
  },
  "defaults": {
    "coverage": "complete",
    "mutation": "tier3",
    "perf": "default"
  },
  "perPackage": {
    "@stynx-web/angular-audit": { "coverage": "default", "mutation": "tier1" },
    "@stynx-web/angular-iam": { "coverage": "default", "mutation": "tier1" },
    "@stynx-web/angular-auth": { "mutation": "tier1" },
    "@stynx-web/angular-flow": { "mutation": "strict" },
    "@stynx-web/angular-profile": { "mutation": "strictest" },
    "@stynx-web/sdk": { "mutation": "tier1" },
    "@stynx-nyx/audit": { "mutation": "tier1" },
    "@stynx-nyx/auth": { "mutation": "tier1" },
    "@stynx-nyx/backend": { "mutation": "strict" },
    "@stynx-nyx/cli": { "mutation": "strict" },
    "@stynx-nyx/data": { "mutation": "tier1" },
    "@stynx-nyx/privacy": { "mutation": "strictest" },
    "@stynx-nyx/tenancy": { "mutation": "tier1" },
    "@stynx-nyx/core": { "mutation": "tier2" },
    "@stynx-nyx/flow": { "mutation": "strict" },
    "@stynx-nyx/i18n": { "mutation": "strict" },
    "@stynx-nyx/idempotency": { "mutation": "tier2" },
    "@stynx-nyx/ratelimit": { "mutation": "tier2" },
    "@stynx-nyx/sessions": { "mutation": "tier2" },
    "@stynx-nyx/storage": { "mutation": "tier2" },
    "@stynx-nyx/testing": { "mutation": "strict" }
  },
  "notApplicable": [
    {
      "packagePattern": "@stynx-domain/demo-bookmark-web",
      "levels": ["Unit", "API", "DB", "E2E", "Mutation", "Coverage"]
    },
    {
      "packagePattern": "@stynx-domain/*",
      "levels": ["E2E", "Mutation"]
    },
    {
      "packagePattern": "@stynx-infra/*",
      "levels": ["API", "DB", "E2E", "Mutation", "Coverage"]
    },
    {
      "packagePattern": "@stynx-nyx/audit",
      "levels": ["E2E"]
    },
    {
      "packagePattern": "@stynx-nyx/auth",
      "levels": ["E2E"]
