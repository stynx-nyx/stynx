{
  "thresholds": {
    "lines": 100,
    "statements": 100,
    "branches": 100,
    "functions": 100
  },
  "policies": {
    "coverage": {
      "default": { "lines": 85, "branches": 80, "functions": 85, "statements": 85 },
      "strict": { "lines": 95, "branches": 95, "functions": 95, "statements": 95 },
      "complete": {
        "lines": 100,
        "branches": 100,
        "functions": 100,
        "statements": 100,
        "branchesTolerance": 0
      },
      "off": { "lines": 0, "branches": 0, "functions": 0, "statements": 0 }
    },
    "mutation": {
      "default": 60,
      "strict": 80,
      "strictest": 85
    },
    "perf": {
      "default": {
        "p50_ms": 5000,
        "p95_ms": 9000,
        "rps_min": 0.2
      }
    }
  },
  "defaults": {
    "coverage": "complete",
    "mutation": "default",
    "perf": "default"
  },
  "perPackage": {
    "@stynx/auth": { "mutation": "strictest" },
    "@stynx/data": { "mutation": "strictest" },
    "@stynx/tenancy": { "mutation": "strict" }
  },
  "notApplicable": [
    {
      "packagePattern": "@stynx-domain/demo-bookmark-web",
      "levels": ["Unit", "API", "DB", "E2E", "Mutation", "Coverage"]
    },
    {
      "packagePattern": "@stynx-domain/*",
      "levels": ["Mutation"]
    },
    {
      "packagePattern": "@stynx-infra/*",
      "levels": ["API", "DB", "E2E", "Mutation", "Coverage"]
    },
    {
      "packagePattern": "@stynx/backend",
      "levels": ["API", "DB"]
    },
    {
      "packagePattern": "@stynx/cli",
      "levels": ["API", "DB"]
    },
    {
      "packagePattern": "@stynx/contracts",
      "levels": ["API", "DB"]
    },
    {
      "packagePattern": "@stynx/core",
      "levels": ["API"]
    },
    {
      "packagePattern": "@stynx/data",
      "levels": ["API"]
    },
    {
      "packagePattern": "@stynx/idempotency",
      "levels": ["API"]
    },
    {
      "packagePattern": "@stynx/logging",
      "levels": ["API"]
    },
    {
      "packagePattern": "@stynx/ratelimit",
      "levels": ["API"]
    },
    {
      "packagePattern": "@stynx/storage",
      "levels": ["API"]
    },
    {
      "packagePattern": "@stynx/testing",
      "levels": ["API", "DB"]
    },
    {
      "packagePattern": "@stynx-web/*",
      "levels": ["API", "DB"]
    },
    {
      "packagePattern": "@stynx/reference-web",
      "levels": ["API", "DB"]
    },
    {
      "packagePattern": "stynx-db-tests",
      "levels": ["API", "E2E", "Mutation", "Coverage"]
    },
    {
      "packagePattern": "stynx-package-tests",
      "levels": ["API", "DB", "E2E", "Mutation", "Coverage"]
    },
    {
      "packagePattern": "stynx-script-tests",
      "levels": ["API", "DB", "E2E", "Mutation", "Coverage"]
    },
    {
      "packagePattern": "@stynx-internal/*",
      "levels": ["API", "DB", "E2E", "Mutation", "Coverage"]
    }
  ]
}
