{
  "name": "@stynx-internal/eslint-config",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Shared flat ESLint config for the STYNX monorepo",
  "exports": {
    ".": "./index.mjs",
    "./lib": "./lib.mjs",
    "./nest": "./nest.mjs",
    "./angular": "./angular.mjs"
  },
  "scripts": {
    "test": "node ../../scripts/run-and-record.mjs --package @stynx-internal/eslint-config --level unit --runner node-test -- node --test test/eslint-config.spec.mjs"
  },
  "files": [
    "*.mjs",
    "README.md"
  ]
}
