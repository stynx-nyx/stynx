{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "paths": {
      "@stech/stynx-backend": ["../../packages/stynx-backend/src/index.ts"],
      "@stech/stynx-contracts": ["../../packages/stynx-contracts/src/index.ts"],
      "@stynx/auth": ["../../packages/auth/src/index.ts"],
      "@stynx/audit": ["../../packages/audit/src/index.ts"],
      "@stynx/cli": ["../../packages/cli/src/index.ts"],
      "@stynx/core": ["../../packages/core/src/index.ts"],
      "@stynx/logging": ["../../packages/logging/src/index.ts"],
      "@stynx/health": ["../../packages/health/src/index.ts"],
      "@stynx/data": ["../../packages/data/src/index.ts"],
      "@stynx/i18n": ["../../packages/i18n/src/index.ts"],
      "@stynx/privacy": ["../../packages/privacy/src/index.ts"],
      "@stynx/ratelimit": ["../../packages/ratelimit/src/index.ts"],
      "@stynx/idempotency": ["../../packages/idempotency/src/index.ts"],
      "@stynx/sessions": ["../../packages/sessions/src/index.ts"],
      "@stynx/storage": ["../../packages/storage/src/index.ts"],
      "@stynx/tenancy": ["../../packages/tenancy/src/index.ts"],
      "@stynx/testing": ["../../packages/testing/src/index.ts"],
      "@stynx/reference-api": ["../../apps/reference-api/src/main.ts"],
      "@stynx/reference-web": ["../../apps/reference-web/src/main.ts"],
      "@stynx-web/sdk": ["../../packages-web/sdk/src/index.ts"],
      "@stynx-web/angular": ["../../packages-web/angular/src/index.ts"],
      "@stynx-web/angular-auth": ["../../packages-web/angular-auth/src/index.ts"],
      "@stynx-web/angular-ui": ["../../packages-web/angular-ui/src/index.ts"],
      "@stynx-web/angular-i18n": ["../../packages-web/angular-i18n/src/index.ts"],
      "@stynx-web/angular-trash": ["../../packages-web/angular-trash/src/index.ts"],
      "@stynx-web/angular-storage": ["../../packages-web/angular-storage/src/index.ts"],
      "@stynx-web/angular-sessions": ["../../packages-web/angular-sessions/src/index.ts"],
      "@stynx-web/angular-profile": ["../../packages-web/angular-profile/src/index.ts"]
    }
  }
}
