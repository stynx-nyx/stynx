{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "paths": {
      "@stynx-nyx/backend": ["../../packages/backend/src/index.ts"],
      "@stynx-nyx/contracts": ["../../packages/contracts/src/index.ts"],
      "@stynx-nyx/auth": ["../../packages/auth/src/index.ts"],
      "@stynx-nyx/audit": ["../../packages/audit/src/index.ts"],
      "@stynx-nyx/cli": ["../../packages/cli/src/index.ts"],
      "@stynx-nyx/core": ["../../packages/core/src/index.ts"],
      "@stynx-nyx/logging": ["../../packages/logging/src/index.ts"],
      "@stynx-nyx/health": ["../../packages/health/src/index.ts"],
      "@stynx-nyx/flow": ["../../packages/flow/src/index.ts"],
      "@stynx-nyx/data": ["../../packages/data/src/index.ts"],
      "@stynx-nyx/i18n": ["../../packages/i18n/src/index.ts"],
      "@stynx-nyx/privacy": ["../../packages/privacy/src/index.ts"],
      "@stynx-nyx/ratelimit": ["../../packages/ratelimit/src/index.ts"],
      "@stynx-nyx/idempotency": ["../../packages/idempotency/src/index.ts"],
      "@stynx-nyx/sessions": ["../../packages/sessions/src/index.ts"],
      "@stynx-nyx/storage": ["../../packages/storage/src/index.ts"],
      "@stynx-nyx/tenancy": ["../../packages/tenancy/src/index.ts"],
      "@stynx-nyx/testing": ["../../packages/testing/src/index.ts"],
      "@stynx-nyx/signature": ["../../packages/signature/src/index.ts"],
      "@stynx-nyx/pdf": ["../../packages/pdf/src/index.ts"],
      "@stynx-nyx/pdf-a": ["../../packages/pdf-a/src/index.ts"],
      "@stynx-nyx/pdf-a-vera-docker": ["../../packages/pdf-a-vera-docker/src/index.ts"],
      "@stynx-nyx/feature-flags": ["../../packages/feature-flags/src/index.ts"],
      "@stynx-nyx/integration-adapter": ["../../packages/integration-adapter/src/index.ts"],
      "@stynx-nyx/reference-api": ["../../reference/api/src/main.ts"],
      "@stynx-nyx/reference-web": ["../../reference/web/src/main.ts"],
      "@stynx-nyx/sdk": ["../../packages-web/sdk/src/index.ts"],
      "@stynx-nyx/angular": ["../../packages-web/angular/src/index.ts"],
      "@stynx-nyx/angular-tenancy": ["../../packages-web/angular-tenancy/src/index.ts"],
      "@stynx-nyx/angular-auth": ["../../packages-web/angular-auth/src/index.ts"],
      "@stynx-nyx/angular-ui": ["../../packages-web/angular-ui/src/index.ts"],
      "@stynx-nyx/angular-i18n": ["../../packages-web/angular-i18n/src/index.ts"],
      "@stynx-nyx/angular-trash": ["../../packages-web/angular-trash/src/index.ts"],
      "@stynx-nyx/angular-storage": ["../../packages-web/angular-storage/src/index.ts"],
      "@stynx-nyx/angular-sessions": ["../../packages-web/angular-sessions/src/index.ts"],
      "@stynx-nyx/angular-profile": ["../../packages-web/angular-profile/src/index.ts"],
      "@stynx-nyx/angular-iam": ["../../packages-web/angular-iam/src/index.ts"],
      "@stynx-nyx/angular-iam/catalogs/*": ["../../packages-web/angular-iam/src/i18n/*"],
      "@stynx-nyx/angular-flow": ["../../packages-web/angular-flow/src/index.ts"]
    }
  }
}
