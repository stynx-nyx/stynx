@@ -0,0 +1,21 @@
+import { Injectable, inject } from '@angular/core';
+import { Observable } from 'rxjs';
+import { ApiService } from '@core/api/api.service';
+import { TenancySummary } from './models';
+
+@Injectable({ providedIn: 'root' })
+export class TenancyService {
+  private readonly api = inject(ApiService);
+
+  list(): Observable<TenancySummary[]> {
+    return this.api.get<TenancySummary[]>('/admin/tenancies');
+  }
+
+  assign(userId: string, tenancyId: string): Observable<void> {
+    return this.api.post<void>(`/admin/users/${userId}/tenancies`, { tenancyId });
+  }
+
+  remove(userId: string, tenancyId: string): Observable<void> {
+    return this.api.post<void>(`/admin/users/${userId}/tenancies/${tenancyId}/remove`, {});
+  }
+}
diff --git a/frontend/src/app/admin/users/user-detail.component.html b/frontend/src/app/admin/users/user-detail.component.html
new file mode 100644
index 0000000..cda46c3
--- /dev/null
+++ b/frontend/src/app/admin/users/user-detail.component.html
@@ -0,0 +1,155 @@
+@if (user() as current) {
+  <section class="user-detail">
+    <header class="user-detail__header">
+      <div>
+        <button mat-button routerLink="/admin/users">
+          <mat-icon>arrow_back</mat-icon>
+          Back to users
+        </button>
+        <h1>{{ current.displayName || current.email || 'User' }}</h1>
+        @if (current.createdAt) {
+          <p class="user-detail__meta">Created {{ current.createdAt | date: 'medium' }}</p>
+        }
+      </div>
+      <div class="user-detail__status" [class.user-detail__status--inactive]="current.status !== 'active'">
+        <mat-icon>{{ current.status === 'active' ? 'verified_user' : 'block' }}</mat-icon>
+        <span>{{ current.status | titlecase }}</span>
+      </div>
+    </header>
+
+    <mat-card>
+      <mat-tab-group>
+        <mat-tab label="Account">
+          <div class="user-detail__tab">
+            <form [formGroup]="accountForm" (ngSubmit)="saveAccount()" class="user-detail__form">
+              <mat-form-field appearance="outline">
+                <mat-label>Email</mat-label>
+                <input matInput formControlName="email" />
+              </mat-form-field>
+              <mat-form-field appearance="outline">
+                <mat-label>Phone</mat-label>
+                <input matInput formControlName="phoneNumber" />
+              </mat-form-field>
+              <div class="user-detail__form-actions">
+                <button mat-flat-button color="primary" type="submit" [disabled]="accountForm.invalid || accountForm.pristine">
+                  Save changes
+                </button>
+                <span class="user-detail__spacer"></span>
+                <button mat-button type="button" (click)="confirmAccount()">Send account confirmation</button>
+              </div>
+            </form>
+            <div class="user-detail__verification">
+              <button mat-stroked-button color="primary" type="button" (click)="confirmEmail()">
+                <mat-icon>mark_email_read</mat-icon>
+                Confirm email
+              </button>
+              <button mat-stroked-button color="primary" type="button" (click)="confirmPhone()">
+                <mat-icon>phone_enabled</mat-icon>
+                Confirm phone
+              </button>
+            </div>
+          </div>
+        </mat-tab>
+
+        <mat-tab label="Roles">
+          <div class="user-detail__tab user-detail__tab--roles">
+            <section>
+              <h3>Assigned roles</h3>
+              @if (current.roles.length) {
+                <mat-chip-set>
+                  @for (role of current.roles; track role.id) {
+                    <mat-chip color="primary" selected>
+                      {{ role.name }}
+                      <button mat-icon-button matChipRemove (click)="removeRole(role)" aria-label="Remove {{ role.name }}">
+                        <mat-icon>close</mat-icon>
+                      </button>
+                    </mat-chip>
+                  }
+                </mat-chip-set>
+              } @else {
+                <p class="user-detail__empty">No roles assigned</p>
+              }
+            </section>
+            <section>
+              <h3>Available roles</h3>
+              @if (availableRoles().length) {
+                <mat-chip-set>
+                  @for (role of availableRoles(); track role.id) {
+                    <mat-chip (click)="addRole(role)" clickable>
+                      {{ role.name }}
+                      <mat-icon matChipTrailingIcon>add</mat-icon>
+                    </mat-chip>
+                  }
+                </mat-chip-set>
+              } @else {
+                <p class="user-detail__empty">All roles assigned</p>
+              }
+            </section>
+          </div>
+        </mat-tab>
+
+        <mat-tab label="Tenancies">
+          <div class="user-detail__tab user-detail__tab--tenancies">
+            <section>
+              <h3>Current tenancies</h3>
+              @if (current.tenancies.length) {
+                <mat-list>
+                  @for (tenancy of current.tenancies; track tenancy.id) {
+                    <mat-list-item>
+                      <div matListItemTitle>{{ tenancy.name }}</div>
+                      <div matListItemLine>{{ tenancy.code }}</div>
+                      <button mat-icon-button color="warn" (click)="removeTenancy(tenancy)">
+                        <mat-icon>delete</mat-icon>
+                      </button>
+                    </mat-list-item>
+                  }
+                </mat-list>
+              } @else {
+                <p class="user-detail__empty">No tenancy affiliations</p>
+              }
+            </section>
+            <section class="user-detail__tenancy-add">
+              <h3>Add tenancy</h3>
+              <mat-form-field appearance="outline">
+                <mat-label>Tenancy</mat-label>
+                <mat-select [formControl]="tenancySelection">
+                  @for (tenancy of availableTenancies(); track tenancy.id) {
+                    <mat-option [value]="tenancy.id">{{ tenancy.name }}</mat-option>
+                  }
+                </mat-select>
+              </mat-form-field>
+              <button mat-flat-button color="primary" type="button" (click)="assignTenancy()" [disabled]="!tenancySelection.value">
+                Assign
+              </button>
+            </section>
+          </div>
+        </mat-tab>
+
+        <mat-tab label="Attributes">
+          <div class="user-detail__tab user-detail__tab--attributes">
+            @if (attributes().length) {
+              <table class="user-detail__attributes">
+                <thead>
+                  <tr>
+                    <th>Key</th>
+                    <th>Value</th>
+                  </tr>
+                </thead>
+                <tbody>
+                  @for (item of attributes(); track item.key) {
+                    <tr>
+                      <td>{{ item.key }}</td>
+                      <td>{{ item.value | json }}</td>
+                    </tr>
+                  }
+                </tbody>
+              </table>
+            } @else {
+              <p class="user-detail__empty">No custom attributes</p>
+            }
+          </div>
+        </mat-tab>
+      </mat-tab-group>
+    </mat-card>
+  </section>
+}
