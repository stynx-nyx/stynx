+    return this.service.listForUser(req.user!.id);
+  }
+
+  @Post()
+  @UseGuards(RoleGuard)
+  @RequireRoles('platform:admin', 'platform:superadmin')
+  @Audit({ action: 'create', entity: 'tenancy' })
+  async create(
+    @Req() req: RequestWithUser,
+    @Body() body: CreateTenancyDto,
+  ): Promise<TenancyDto> {
