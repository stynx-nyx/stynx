-+import { MatDialog } from '@angular/material/dialog';
-+
-+interface StorageFileVm {
-+  fileId: string;
-+  filename: string;
-+  mimeType: string | null;
-+  bucket: string;
-+  objectKey: string;
-+  createdAt: string;
-+}
-+
-+@Component({
-+  standalone: true,
-+  selector: 'stc-storage-explorer',
