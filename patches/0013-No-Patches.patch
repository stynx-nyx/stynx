-+})
-+export class AdminTenanciesComponent {
-+  private readonly refresh$ = new BehaviorSubject<void>(undefined);
-+  readonly form = this.fb.group({
-+    code: ['', [Validators.required, Validators.pattern(/^[a-z0-9-]+$/)]],
-+    name: ['', Validators.required],
