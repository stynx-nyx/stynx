{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["package.json", "pnpm-workspace.yaml", "turbo.json"],
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "CI_LOCAL_HOST_DOCKER",
    "STYNX_DATABASE_URL",
    "STYNX_TEST_PG_HOST",
    "STYNX_TEST_PG_PASSWORD",
    "STYNX_TEST_PG_PORT",
    "STYNX_TEST_PG_USER",
    "TESTCONTAINERS_HOST_OVERRIDE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build", "^build"],
      "outputs": []
    },
    "test:int": {
      "dependsOn": ["build", "^build"],
      "outputs": []
    }
  }
}
