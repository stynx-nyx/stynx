{
  "name": "stynx-backend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "rimraf dist && nest build",
    "lint": "eslint --config ../tools/eslint-config/nest.mjs \"src/**/*.ts\"",
    "test": "npm --prefix ../test/backend run test",
    "test:watch": "npm --prefix ../test/backend run test:watch",
    "test:cov": "npm --prefix ../test/backend run test:cov",
    "swagger:export": "ts-node -r tsconfig-paths/register src/core/docs/swagger.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1037.0",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/credential-providers": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.1",
    "@stynx/data": "workspace:*",
    "@stynx/idempotency": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.1.0",
    "jose": "^6.2.2",
    "jwks-rsa": "^4.0.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
