{
  "schemaVersion": "1.0.0",
  "project_type": "runtime-host",
  "devai_version": "0.3.0",
  "constitution": {
    "version": "0.2.0"
  },
  "repo": {
    "kind": "library"
  },
  "docs": {
    "builder": "docusaurus",
    "build_command": "pnpm --filter @stynx-nyx/docs-site run build",
    "output_dir": "docs/site/build",
    "publish_target": "gh-pages",
    "gh_pages_branch": "gh-pages"
  },
  "ci_economy": {
    "local_evidence": {
      "manifest_path": ".ci/evidence/local-ci.json",
      "max_age_hours": 24,
      "required_jobs": ["all-linux", "stynx-release"],
      "allowed_platforms": ["linux/arm64", "linux/amd64"],
      "forbidden_paths": ["infra/github/"],
      "require_docker": true
    }
  }
}
