{
  "schemaVersion": "1.0.0",
  "id": "BP-DEMO-BOOKMARK-001",
  "module": {
    "name": "Bookmark",
    "namespace": "demo",
    "version": "1.0.0"
  },
  "database": {
    "entities": [
      {
        "name": "Bookmark",
        "primaryKey": ["id"],
        "fields": [
          { "name": "id", "type": "uuid", "default": "gen_random_uuid()" },
          { "name": "url", "type": "varchar(2048)" },
          { "name": "title", "type": "varchar(140)" },
          { "name": "note", "type": "text", "nullable": true },
          { "name": "tags_count", "type": "int", "default": "0" },
          { "name": "is_archived", "type": "bool", "default": "false" },
          { "name": "created_at", "type": "timestamptz", "default": "now()" },
          { "name": "updated_at", "type": "timestamptz", "default": "now()" }
        ]
      }
    ]
  },
  "api": {
    "basePath": "/api",
    "resources": [
      {
        "entity": "Bookmark",
        "operations": ["list", "get", "create", "update", "delete"]
      }
    ]
  },
  "auth": {
    "rbac": {
      "roles": ["admin", "user"],
      "permissions": [
        { "role": "admin", "allow": ["manage"] },
        { "role": "user", "allow": ["list", "get", "create"] }
      ]
    }
  }
}
