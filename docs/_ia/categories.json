{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "R15 W04 deliverable. Authored category manifest declaring per-directory order + labels for the seven top-level sections and any sub-categories within them. Shape follows DEVAI's docs/_ia/categories.json (sections + categories + rootFileAllowlist), NOT the alternate shape sketched in this round's W04 worker prompt. Consumed by docs/site/scripts/sync-content.mjs (or its R15 W06 successor) which emits _category_.json files into the synced Docusaurus tree. Per ADR-DOCS-IA Decision 5, this is the only authorised way to reorder a category in the published site.",
  "sections": [
    { "id": "start", "label": "Start here", "position": 1 },
    { "id": "theory", "label": "Theory", "position": 2 },
    { "id": "framework", "label": "Framework", "position": 3 },
    { "id": "roles", "label": "Roles", "position": 4 },
    { "id": "adopters", "label": "Adopters", "position": 5 },
    { "id": "reference", "label": "Reference", "position": 6 },
    { "id": "meta", "label": "Meta", "position": 7 }
  ],
  "categories": {
    "framework/api": { "label": "API", "position": 1 },
    "framework/arch": { "label": "Architecture", "position": 2 },
    "framework/contracts": { "label": "Contracts", "position": 3 },
    "framework/schemas": { "label": "Schemas", "position": 4 },
    "framework/product": { "label": "Product (Owner specs)", "position": 7 },
    "framework/glossary": { "label": "Glossary", "position": 8 },
    "adopters/pilots": { "label": "Pilots", "position": 2 },
    "adopters/stynx": { "label": "STYNX adoption pack", "position": 3 },
    "meta/adr": { "label": "ADRs", "position": 1 },
    "meta/dev": { "label": "Development", "position": 2 },
    "meta/eng": { "label": "Engineering", "position": 3 },
    "meta/gov": { "label": "Governance", "position": 4 },
    "meta/ops": { "label": "Operations", "position": 5 },
    "meta/security": { "label": "Security", "position": 6 },
    "meta/sys": { "label": "Systems", "position": 7 },
    "meta/rfcs": { "label": "RFCs", "position": 8 },
    "meta/templates": { "label": "Templates", "position": 9 },
    "meta/legacy": { "label": "Legacy (archived)", "position": 10 }
  },
  "rootFileAllowlist": [
    { "source": "README.md", "dest": "start/readme.md", "section": "start" },
    { "source": "CHANGELOG.md", "dest": "meta/changelog.md", "section": "meta" },
    { "source": "CONTRIBUTING.md", "dest": "meta/contributing.md", "section": "meta" },
    { "source": "GOVERNANCE.md", "dest": "meta/governance.md", "section": "meta" },
    { "source": "AGENTS.md", "dest": "meta/agents.md", "section": "meta" },
    { "source": "CLAUDE.md", "dest": "meta/claude.md", "section": "meta" }
  ],
  "outOfIa": ["work/", "_ia/", "site/"]
}
