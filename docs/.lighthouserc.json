{
  "ci": {
    "collect": {
      "staticDistDir": "./build",
      "settings": {
        "chromeFlags": "--headless=new --disable-gpu --disable-dev-shm-usage --no-sandbox --no-first-run --no-default-browser-check --remote-debugging-port=9222 --user-data-dir=/tmp/stynx-lhci-profile"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./build/lighthouse"
    }
  }
}
