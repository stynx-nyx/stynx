{
  "name": "@stynx-web/angular-audit",
  "version": "0.1.0",
  "description": "Angular read-only audit report surfaces for stynx web apps",
  "exports": {
    ".": {
      "types": "./dist/types/stynx-web-angular-audit.d.ts",
      "default": "./dist/fesm2022/stynx-web-angular-audit.mjs"
    },
    "./testing": {
      "types": "./dist/types/stynx-web-angular-audit-testing.d.ts",
      "default": "./dist/fesm2022/stynx-web-angular-audit-testing.mjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=24 <25"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.spec.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/angular.mjs \"src/**/*.ts\"",
    "test": "node ./../../scripts/run-and-record.mjs --package @stynx-web/angular-audit --level unit --runner vitest -- vitest run --config ./vitest.config.ts",
    "build:tsc": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "rxjs": "^7.8.2"
  },
  "peerDependencies": {
    "@angular/common": "^20.2.0",
    "@angular/core": "^20.2.0",
    "@angular/forms": "^20.2.0",
    "@angular/router": "^20.2.0",
    "@stynx-web/angular": "workspace:*",
    "@stynx-web/angular-auth": "workspace:*",
    "@stynx-web/angular-i18n": "workspace:*",
    "@stynx-web/angular-ui": "workspace:*",
    "@stynx-web/sdk": "workspace:*"
  },
  "devDependencies": {
    "@angular/common": "22.0.0-rc.0",
    "@angular/compiler": "22.0.0-rc.0",
    "@angular/compiler-cli": "22.0.0-rc.0",
    "@angular/core": "22.0.0-rc.0",
    "@angular/forms": "22.0.0-rc.0",
    "@angular/platform-browser": "22.0.0-rc.0",
    "@angular/router": "22.0.0-rc.0",
    "@stynx-web/angular": "workspace:*",
    "@stynx-web/angular-auth": "workspace:*",
    "@stynx-web/angular-i18n": "workspace:*",
    "@stynx-web/angular-ui": "workspace:*",
    "@stynx-web/sdk": "workspace:*",
    "@types/node": "^25.9.1",
    "jsdom": "^29.0.2",
    "ng-packagr": "22.0.0-rc.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  }
}
