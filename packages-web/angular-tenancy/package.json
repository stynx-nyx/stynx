{
  "name": "@stynx-web/angular-tenancy",
  "version": "0.1.0",
  "description": "Angular tenant context and X-Tenant-Id integration for STYNX applications",
  "main": "dist/angular-tenancy/src/index.js",
  "types": "dist/angular-tenancy/src/index.d.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/angular-tenancy/src/index.d.ts",
      "require": "./dist/angular-tenancy/src/index.js",
      "default": "./dist/angular-tenancy/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.spec.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/angular.mjs \"src/**/*.ts\"",
    "test": "node ./../../scripts/run-and-record.mjs --package @stynx-web/angular-tenancy --level unit --runner vitest -- vitest run --config ./vitest.config.ts",
    "stryker": "node ./../../scripts/run-and-record.mjs --package @stynx-web/angular-tenancy --level mutation --runner stryker-vitest -- NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --experimental-vm-modules\" pnpm exec stryker run stryker.conf.mjs",
    "test:e2e": "echo \"test:e2e removed during V6 cutover; convert to vitest if needed\" && false"
  },
  "dependencies": {
    "rxjs": "^7.8.2"
  },
  "peerDependencies": {
    "@angular/common": "^20.2.0",
    "@angular/core": "^20.2.0",
    "@angular/forms": "^20.2.0"
  },
  "devDependencies": {
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/compiler-cli": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/forms": "^21.2.10",
    "@angular/platform-browser": "^21.2.10",
    "@types/node": "^25.6.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3"
  }
}
