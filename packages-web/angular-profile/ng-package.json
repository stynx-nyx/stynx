{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "dist",
  "lib": {
    "entryFile": "src/index.ts"
  },
  "assets": [
    {
      "glob": "*.json",
      "input": "src/i18n",
      "output": "catalogs"
    }
  ],
  "allowedNonPeerDependencies": ["@stynx-web/*", "angular-auth-oidc-client", "rxjs"]
}
