{
  "name": "@stynx-web/angular-storage",
  "version": "1.0.0",
  "description": "Angular 20 document upload components for stynx",
  "main": "dist/angular-storage/src/index.js",
  "types": "dist/angular-storage/src/index.d.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/angular-storage/src/index.d.ts",
      "require": "./dist/angular-storage/src/index.js",
      "default": "./dist/angular-storage/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.spec.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/angular.mjs \"src/**/*.ts\"",
    "test": "vitest run --config ./vitest.config.ts",
    "stryker": "NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --experimental-vm-modules\" pnpm exec stryker run stryker.conf.mjs",
    "test:e2e": "echo \"test:e2e removed during V6 cutover; convert to vitest if needed\" && false"
  },
  "dependencies": {
    "@stynx-web/angular": "workspace:*",
    "@stynx-web/angular-ui": "workspace:*",
    "rxjs": "^7.8.2"
  },
  "peerDependencies": {
    "@angular/common": "^20.2.0",
    "@angular/core": "^20.2.0"
  },
  "devDependencies": {
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/compiler-cli": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@types/node": "^25.6.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3"
  }
}
