{
  "name": "@stynx-nyx/angular",
  "version": "1.0.2",
  "description": "Angular core integration for stynx",
  "exports": {
    ".": {
      "types": "./dist/types/stynx-nyx-angular.d.ts",
      "default": "./dist/fesm2022/stynx-nyx-angular.mjs"
    },
    "./testing": {
      "types": "./dist/types/stynx-nyx-angular-testing.d.ts",
      "default": "./dist/fesm2022/stynx-nyx-angular-testing.mjs"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=24 <25"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.spec.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/angular.mjs \"src/**/*.ts\"",
    "test": "vitest run --config ./vitest.config.ts",
    "stryker": "NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --experimental-vm-modules\" pnpm exec stryker run stryker.conf.mjs",
    "build:tsc": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@stynx-nyx/angular-tenancy": "workspace:*",
    "@stynx-nyx/sdk": "workspace:*",
    "rxjs": "^7.8.2"
  },
  "peerDependencies": {
    "@angular/common": ">=20.3.0 <22",
    "@angular/core": ">=20.3.0 <22",
    "@angular/router": ">=20.3.0 <22"
  },
  "devDependencies": {
    "@angular/common": "21.2.18",
    "@angular/compiler": "21.2.18",
    "@angular/compiler-cli": "21.2.18",
    "@angular/core": "21.2.18",
    "@angular/platform-browser": "21.2.18",
    "@angular/platform-browser-dynamic": "21.2.18",
    "@angular/router": "21.2.18",
    "@types/node": "26.1.1",
    "cross-env": "^10.1.0",
    "jsdom": "^29.0.2",
    "ng-packagr": "21.2.3",
    "tslib": "^2.8.1",
    "typescript": "7.0.2"
  }
}
