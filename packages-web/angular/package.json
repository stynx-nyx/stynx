{
  "name": "@stynx-web/angular",
  "version": "1.0.0",
  "description": "Angular core integration for stynx",
  "exports": {
    ".": {
      "types": "./dist/types/stynx-web-angular.d.ts",
      "default": "./dist/fesm2022/stynx-web-angular.mjs"
    },
    "./testing": {
      "types": "./dist/types/stynx-web-angular-testing.d.ts",
      "default": "./dist/fesm2022/stynx-web-angular-testing.mjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=24 <25"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.spec.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/angular.mjs \"src/**/*.ts\"",
    "test": "vitest run --config ./vitest.config.ts",
    "stryker": "NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --experimental-vm-modules\" pnpm exec stryker run stryker.conf.mjs",
    "build:tsc": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@stynx-web/angular-tenancy": "workspace:*",
    "@stynx-web/sdk": "workspace:*",
    "rxjs": "^7.8.2"
  },
  "peerDependencies": {
    "@angular/common": "^20.2.0",
    "@angular/core": "^20.2.0",
    "@angular/router": "^20.2.0"
  },
  "devDependencies": {
    "@angular/common": "22.0.0-rc.0",
    "@angular/compiler": "22.0.0-rc.0",
    "@angular/compiler-cli": "22.0.0-rc.0",
    "@angular/core": "22.0.0-rc.0",
    "@angular/platform-browser": "22.0.0-rc.0",
    "@angular/platform-browser-dynamic": "22.0.0-rc.0",
    "@angular/router": "22.0.0-rc.0",
    "@types/node": "^25.9.1",
    "cross-env": "^10.1.0",
    "jsdom": "^29.0.2",
    "ng-packagr": "22.0.0-rc.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  }
}
