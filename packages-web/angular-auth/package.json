{
  "name": "@stynx-web/angular-auth",
  "version": "1.0.0",
  "description": "Angular authentication and session integration for stynx",
  "exports": {
    ".": {
      "types": "./dist/types/stynx-web-angular-auth.d.ts",
      "default": "./dist/fesm2022/stynx-web-angular-auth.mjs"
    },
    "./testing": {
      "types": "./dist/types/stynx-web-angular-auth-testing.d.ts",
      "default": "./dist/fesm2022/stynx-web-angular-auth-testing.mjs"
    },
    "./catalogs/en.json": "./dist/catalogs/en.json",
    "./catalogs/pt-BR.json": "./dist/catalogs/pt-BR.json",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=24 <25"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json && pnpm run normalize:dist-exports",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.spec.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/angular.mjs \"src/**/*.ts\"",
    "test": "node ./../../scripts/run-and-record.mjs --package @stynx-web/angular-auth --level unit --runner vitest -- vitest run --config ./vitest.config.ts",
    "stryker": "node ./../../scripts/run-and-record.mjs --package @stynx-web/angular-auth --level mutation --runner stryker-vitest -- NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --experimental-vm-modules\" pnpm exec stryker run stryker.conf.mjs",
    "normalize:dist-exports": "node -e \"const fs=require('node:fs');const path='dist/package.json';const pkg=JSON.parse(fs.readFileSync(path,'utf8'));pkg.exports['./catalogs/en.json']='./catalogs/en.json';pkg.exports['./catalogs/pt-BR.json']='./catalogs/pt-BR.json';fs.writeFileSync(path, JSON.stringify(pkg,null,2)+'\\n');\"",
    "build:tsc": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@stynx-web/angular": "workspace:*",
    "@stynx-web/angular-i18n": "workspace:*",
    "@stynx-web/sdk": "workspace:*",
    "angular-auth-oidc-client": "^21.0.2",
    "rxjs": "^7.8.2"
  },
  "peerDependencies": {
    "@angular/common": "^20.2.0",
    "@angular/core": "^20.2.0",
    "@angular/forms": "^20.2.0",
    "@angular/router": "^20.2.0"
  },
  "devDependencies": {
    "@angular/common": "22.0.0-rc.0",
    "@angular/compiler": "22.0.0-rc.0",
    "@angular/compiler-cli": "22.0.0-rc.0",
    "@angular/core": "22.0.0-rc.0",
    "@angular/forms": "22.0.0-rc.0",
    "@angular/platform-browser": "22.0.0-rc.0",
    "@angular/router": "22.0.0-rc.0",
    "@types/node": "^25.6.0",
    "jsdom": "^29.0.2",
    "ng-packagr": "22.0.0-rc.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  }
}
