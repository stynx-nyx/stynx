{
  "name": "@stynx-nyx/reference-web",
  "private": true,
  "version": "0.2.1",
  "description": "Reference Angular 20 app exercising the STYNX web packages against reference-api",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:web": "node scripts/build-web.mjs",
    "clean": "find dist .playwright -mindepth 0 -maxdepth 0 -exec rm -rf {} + 2>/dev/null || true",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/angular.mjs \"src/**/*.ts\"",
    "serve": "node scripts/serve-static.mjs",
    "test": "node --test test/unit/reference-web-config.spec.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@angular/common": "21.2.15",
    "@angular/compiler": "21.2.15",
    "@angular/core": "21.2.15",
    "@angular/forms": "21.2.15",
    "@angular/platform-browser": "21.2.15",
    "@angular/platform-browser-dynamic": "21.2.15",
    "@angular/router": "21.2.15",
    "@stynx-nyx/angular": "workspace:*",
    "@stynx-nyx/angular-auth": "workspace:*",
    "@stynx-nyx/angular-flow": "workspace:*",
    "@stynx-nyx/angular-iam": "workspace:*",
    "@stynx-nyx/angular-tenancy": "workspace:*",
    "@stynx-nyx/angular-i18n": "workspace:*",
    "@stynx-nyx/angular-profile": "workspace:*",
    "@stynx-nyx/angular-sessions": "workspace:*",
    "@stynx-nyx/angular-storage": "workspace:*",
    "@stynx-nyx/angular-trash": "workspace:*",
    "@stynx-nyx/angular-ui": "workspace:*",
    "angular-auth-oidc-client": "^21.0.1",
    "rxjs": "^7.8.2",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "esbuild": "^0.28.0",
    "typescript": "5.9.3"
  }
}
