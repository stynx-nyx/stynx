{
  "name": "@stynx/reference-web",
  "private": true,
  "version": "0.2.1",
  "description": "Reference Angular 20 app exercising the STYNX web packages against reference-api",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:web": "node scripts/build-web.mjs",
    "clean": "find dist .playwright -mindepth 0 -maxdepth 0 -exec rm -rf {} + 2>/dev/null || true",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/angular.mjs \"src/**/*.ts\"",
    "serve": "node scripts/serve-static.mjs",
    "test": "node ../../scripts/run-and-record.mjs --package @stynx/reference-web --level unit --runner node-test -- node --test test/unit/reference-web-config.spec.mjs",
    "test:e2e": "node ../../scripts/run-and-record.mjs --package @stynx/reference-web --level e2e --runner playwright -- playwright test"
  },
  "dependencies": {
    "@angular/common": "22.0.0-rc.0",
    "@angular/compiler": "22.0.0-rc.0",
    "@angular/core": "22.0.0-rc.0",
    "@angular/forms": "22.0.0-rc.0",
    "@angular/platform-browser": "22.0.0-rc.0",
    "@angular/platform-browser-dynamic": "22.0.0-rc.0",
    "@angular/router": "22.0.0-rc.0",
    "@stynx-web/angular": "workspace:*",
    "@stynx-web/angular-auth": "workspace:*",
    "@stynx-web/angular-flow": "workspace:*",
    "@stynx-web/angular-iam": "workspace:*",
    "@stynx-web/angular-tenancy": "workspace:*",
    "@stynx-web/angular-i18n": "workspace:*",
    "@stynx-web/angular-profile": "workspace:*",
    "@stynx-web/angular-sessions": "workspace:*",
    "@stynx-web/angular-storage": "workspace:*",
    "@stynx-web/angular-trash": "workspace:*",
    "@stynx-web/angular-ui": "workspace:*",
    "angular-auth-oidc-client": "^21.0.1",
    "rxjs": "^7.8.2",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
