{
  "name": "@stynx/data",
  "version": "0.1.0",
  "description": "Data access foundation for stynx",
  "main": "dist/data/src/index.js",
  "types": "dist/data/src/index.d.ts",
  "engines": {
    "node": ">=20 <23"
  },
  "exports": {
    ".": {
      "types": "./dist/data/src/index.d.ts",
      "require": "./dist/data/src/index.js",
      "default": "./dist/data/src/index.js"
    }
  },
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/nest.mjs \"src/**/*.ts\"",
    "test": "jest --config ./jest.config.cjs",
    "test:int": "jest --config ./jest.integration.config.cjs",
    "stryker": "pnpm exec stryker run stryker.conf.mjs"
  },
  "dependencies": {
    "@stynx/core": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "nestjs-cls": "^6.2.0",
    "pg": "^8.16.3",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@types/jest": "^29.5.12",
    "@types/pg": "^8.15.5",
    "jest": "^29.7.0",
    "testcontainers": "^11.7.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
