{
  "name": "@stynx-nyx/data",
  "version": "1.0.1",
  "description": "Data access foundation for stynx",
  "main": "dist/data/src/index.js",
  "types": "dist/data/src/index.d.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/data/src/index.d.ts",
      "require": "./dist/data/src/index.js",
      "default": "./dist/data/src/index.js"
    }
  },
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/nest.mjs \"src/**/*.ts\"",
    "test": "vitest run --config ./vitest.config.ts",
    "test:int": "vitest run --config ./vitest.int.config.ts",
    "stryker": "pnpm exec stryker run stryker.conf.mjs"
  },
  "dependencies": {
    "@stynx-nyx/core": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "nestjs-cls": "^6.2.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@types/node": "26.1.1",
    "@types/pg": "^8.20.0",
    "testcontainers": "^11.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2"
  }
}
