{
  "name": "@stynx-nyx/pdf-a-vera-docker",
  "version": "0.2.2",
  "license": "BUSL-1.1",
  "author": "Antonio Augusto Russo <aarusso@nyxk.com.br>",
  "description": "veraPDF Docker adapter for the stynx PDF/A validator contract",
  "main": "dist/pdf-a-vera-docker/src/index.js",
  "types": "dist/pdf-a-vera-docker/src/index.d.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/pdf-a-vera-docker/src/index.d.ts",
      "require": "./dist/pdf-a-vera-docker/src/index.js",
      "default": "./dist/pdf-a-vera-docker/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/nest.mjs \"src/**/*.ts\"",
    "test": "vitest run --config ./vitest.config.ts",
    "bench": "vitest run --config ./vitest.config.ts test/bench/throughput.bench.ts"
  },
  "dependencies": {
    "@stynx-nyx/pdf-a": "workspace:*"
  },
  "peerDependencies": {
    "@stynx-nyx/logging": "^1.0.2"
  },
  "peerDependenciesMeta": {
    "@stynx-nyx/logging": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stynx-nyx/logging": "workspace:*",
    "@types/node": "24.12.4",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stynx-nyx/stynx.git",
    "directory": "packages/pdf-a-vera-docker"
  }
}
