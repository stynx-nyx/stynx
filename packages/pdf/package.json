{
  "name": "@stynx/pdf",
  "version": "0.1.0",
  "description": "Server-side PDF generation facade for stynx",
  "main": "dist/pdf/src/index.js",
  "types": "dist/pdf/src/index.d.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/pdf/src/index.d.ts",
      "require": "./dist/pdf/src/index.js",
      "default": "./dist/pdf/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/nest.mjs \"src/**/*.ts\"",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "dependencies": {
    "handlebars": "4.7.9",
    "playwright": "^1.60.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "stynxProviderDependencies": {
    "templateEngines": [
      "handlebars",
      "html"
    ],
    "pdfRenderer": "provider-supplied Chromium, Playwright, or equivalent renderer"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.23",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
