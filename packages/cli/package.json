{
  "name": "@stynx/cli",
  "version": "0.1.0",
  "description": "CLI for bootstrapping, doctor checks, migrations, privacy ROPA, and adoption helpers",
  "main": "dist/cli/src/index.js",
  "types": "dist/cli/src/index.d.ts",
  "bin": {
    "stynx": "dist/cli/src/main.js"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/cli/src/index.d.ts",
      "require": "./dist/cli/src/index.js",
      "default": "./dist/cli/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/lib.mjs \"src/**/*.ts\"",
    "test": "jest --config ./jest.config.cjs",
    "test:adopt": "jest --config ./jest.config.cjs --runTestsByPath ./test/adopt.spec.ts"
  },
  "dependencies": {
    "@stynx/privacy": "workspace:*",
    "commander": "^14.0.3",
    "pg": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
