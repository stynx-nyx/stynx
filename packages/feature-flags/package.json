{
  "name": "@stynx-nyx/feature-flags",
  "version": "0.2.2",
  "license": "BUSL-1.1",
  "author": "Antonio Augusto Russo <aarusso@nyxk.com.br>",
  "description": "Tenant and environment scoped feature flag provider for stynx",
  "main": "dist/feature-flags/src/index.js",
  "types": "dist/feature-flags/src/index.d.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/feature-flags/src/index.d.ts",
      "require": "./dist/feature-flags/src/index.js",
      "default": "./dist/feature-flags/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/nest.mjs \"src/**/*.ts\"",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stynx-nyx/stynx.git",
    "directory": "packages/feature-flags"
  }
}
