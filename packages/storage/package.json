{
  "name": "@stynx/storage",
  "version": "0.1.0",
  "description": "Storage adapters and document primitives for stynx",
  "main": "dist/storage/src/index.js",
  "types": "dist/storage/src/index.d.ts",
  "engines": {
    "node": ">=20 <23"
  },
  "exports": {
    ".": {
      "types": "./dist/storage/src/index.d.ts",
      "require": "./dist/storage/src/index.js",
      "default": "./dist/storage/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/nest.mjs \"src/**/*.ts\"",
    "test": "jest --config ./jest.config.cjs",
    "test:int": "NODE_OPTIONS='--experimental-vm-modules' jest --config ./jest.integration.config.cjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1034.0",
    "@aws-sdk/s3-request-presigner": "^3.1034.0",
    "@nestjs/schedule": "^6.0.1",
    "@stech/stynx-contracts": "workspace:*",
    "@stynx/core": "workspace:*",
    "@stynx/data": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/testing": "^11.1.19",
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.4",
    "testcontainers": "^11.7.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
