{
  "name": "@stynx/i18n",
  "version": "1.0.0",
  "description": "Catalog aggregation, locale resolution, and localized error rendering for stynx",
  "main": "dist/i18n/src/index.js",
  "types": "dist/i18n/src/index.d.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/i18n/src/index.d.ts",
      "require": "./dist/i18n/src/index.js",
      "default": "./dist/i18n/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/nest.mjs \"src/**/*.ts\"",
    "test": "vitest run --config ./vitest.config.ts",
    "test:int": "vitest run --config ./vitest.int.config.ts",
    "stryker": "pnpm exec stryker run stryker.conf.mjs"
  },
  "dependencies": {
    "@stynx/core": "workspace:*",
    "@stynx/data": "workspace:*",
    "intl-messageformat": "^11.2.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/testing": "^11.1.19",
    "@stynx/testing": "workspace:*",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
