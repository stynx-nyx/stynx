{
  "name": "@stynx/testing",
  "version": "1.0.0",
  "description": "Testing harness and archive-aware matchers for stynx consumers",
  "main": "dist/testing/src/index.js",
  "types": "dist/testing/src/index.d.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/testing/src/index.d.ts",
      "require": "./dist/testing/src/index.js",
      "default": "./dist/testing/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/nest.mjs \"src/**/*.ts\"",
    "test": "vitest run --config ./vitest.config.ts",
    "stryker": "pnpm exec stryker run stryker.conf.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.23",
    "@nestjs/core": "^11.1.23",
    "@nestjs/platform-express": "^11.1.23",
    "@nestjs/testing": "^11.1.23",
    "@stynx/audit": "workspace:*",
    "@stynx/auth": "workspace:*",
    "@stynx/core": "workspace:*",
    "@stynx/data": "workspace:*",
    "@stynx/sessions": "workspace:*",
    "@stynx/storage": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "testcontainers": "^11.14.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
