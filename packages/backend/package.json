{
  "name": "@stynx-nyx/backend",
  "version": "1.0.0",
  "description": "NestJS shared platform modules for stynx",
  "main": "dist/backend/src/index.js",
  "types": "dist/backend/src/index.d.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/backend/src/index.d.ts",
      "require": "./dist/backend/src/index.js",
      "default": "./dist/backend/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/nest.mjs \"src/**/*.ts\"",
    "test": "vitest run --config ./vitest.config.ts",
    "test:coverage": "vitest run --config ./vitest.config.ts --coverage --coverage.reporter=json",
    "stryker": "pnpm exec stryker run stryker.conf.mjs"
  },
  "dependencies": {
    "@stynx-nyx/idempotency": "workspace:*",
    "@stynx-nyx/ratelimit": "workspace:*",
    "@stynx-nyx/contracts": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@types/node": "24.12.4"
  }
}
