{
  "name": "@stech/stynx-contracts",
  "version": "0.2.0",
  "description": "Framework-agnostic contracts for stynx shared platform packages",
  "main": "dist/stynx-contracts/src/index.js",
  "types": "dist/stynx-contracts/src/index.d.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/stynx-contracts/src/index.d.ts",
      "require": "./dist/stynx-contracts/src/index.js",
      "default": "./dist/stynx-contracts/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/lib.mjs \"src/**/*.ts\""
  }
}
