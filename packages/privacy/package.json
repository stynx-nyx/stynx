{
  "name": "@stynx/privacy",
  "version": "0.1.0",
  "description": "Privacy exports, erasure orchestration, and ROPA generation for stynx",
  "main": "dist/privacy/src/index.js",
  "types": "dist/privacy/src/index.d.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/privacy/src/index.d.ts",
      "require": "./dist/privacy/src/index.js",
      "default": "./dist/privacy/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/nest.mjs \"src/**/*.ts\"",
    "test": "jest --config ./jest.config.cjs",
    "test:int": "jest --config ./jest.integration.config.cjs"
  },
  "dependencies": {
    "@stynx/core": "workspace:*",
    "@stynx/data": "workspace:*",
    "@stynx/storage": "workspace:*",
    "jszip": "^3.10.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/testing": "^11.1.19",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
