{
  "name": "@stynx/ratelimit",
  "version": "1.0.0",
  "description": "Rate limiting primitives for stynx",
  "main": "dist/ratelimit/src/index.js",
  "types": "dist/ratelimit/src/index.d.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/ratelimit/src/index.d.ts",
      "require": "./dist/ratelimit/src/index.js",
      "default": "./dist/ratelimit/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/nest.mjs \"src/**/*.ts\"",
    "test": "vitest run --config ./vitest.config.ts",
    "test:int": "vitest run --config ./vitest.int.config.ts",
    "stryker": "pnpm exec stryker run stryker.conf.mjs"
  },
  "dependencies": {
    "@stynx/auth": "workspace:*",
    "@stynx/data": "workspace:*",
    "redis": "^5.12.1"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3"
  }
}
