{
  "name": "@stynx/auth",
  "version": "0.1.0",
  "description": "Authentication adapters and runtime primitives for stynx",
  "main": "dist/auth/src/index.js",
  "types": "dist/auth/src/index.d.ts",
  "engines": {
    "node": ">=20 <23"
  },
  "exports": {
    ".": {
      "types": "./dist/auth/src/index.d.ts",
      "require": "./dist/auth/src/index.js",
      "default": "./dist/auth/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/nest.mjs \"src/**/*.ts\"",
    "test": "jest --config ./jest.config.cjs",
    "test:int": "jest --config ./jest.integration.config.cjs",
    "stryker": "pnpm exec stryker run stryker.conf.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1034.0",
    "@aws-sdk/credential-providers": "^3.1034.0",
    "@aws-sdk/types": "^3.973.8",
    "@stynx/core": "workspace:*",
    "@stynx/data": "workspace:*",
    "@stynx/idempotency": "workspace:*",
    "@stynx/sessions": "workspace:*",
    "@stech/stynx-contracts": "workspace:*",
    "jose": "^6.2.2",
    "redis": "^5.12.1",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/testing": "^11.1.19",
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
