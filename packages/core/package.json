{
  "name": "@stynx-nyx/core",
  "version": "1.0.1",
  "license": "BUSL-1.1",
  "author": "Antonio Augusto Russo <aarusso@nyxk.com.br>",
  "description": "Core runtime primitives for stynx packages",
  "main": "dist/core/src/index.js",
  "types": "dist/core/src/index.d.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/core/src/index.d.ts",
      "require": "./dist/core/src/index.js",
      "default": "./dist/core/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "@stynx:emit-openapi": "node ./scripts/emit-openapi.mjs",
    "build": "tsc -p tsconfig.json && pnpm run @stynx:emit-openapi",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/nest.mjs \"src/**/*.ts\"",
    "test": "vitest run --config ./vitest.config.ts",
    "test:int": "vitest run --config ./vitest.int.config.ts",
    "stryker": "pnpm exec stryker run stryker.conf.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1037.0",
    "@aws-sdk/client-ssm": "^3.1037.0",
    "nestjs-cls": "^6.2.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/testing": "^11.1.19",
    "@types/node": "24.12.4",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
