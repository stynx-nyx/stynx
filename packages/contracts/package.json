{
  "name": "@stynx/contracts",
  "version": "1.0.0",
  "description": "Framework-agnostic STYNX contracts shared by backend and integration packages",
  "main": "dist/contracts/src/index.js",
  "types": "dist/contracts/src/index.d.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/contracts/src/index.d.ts",
      "require": "./dist/contracts/src/index.js",
      "default": "./dist/contracts/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/lib.mjs \"src/**/*.ts\"",
    "test": "node ../../scripts/record-test-artifact.mjs turbo-test.log -- jest --config ./jest.config.cjs",
    "test:coverage": "jest --config ./jest.config.cjs --coverage --coverageReporters=json"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9"
  }
}
