{
  "name": "@stynx-nyx/contracts",
  "version": "1.0.3",
  "license": "BUSL-1.1",
  "author": "Antonio Augusto Russo <aarusso@nyxk.com.br>",
  "description": "Framework-agnostic STYNX contracts shared by backend and integration packages",
  "main": "dist/contracts/src/index.js",
  "types": "dist/contracts/src/index.d.ts",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/contracts/src/index.d.ts",
      "require": "./dist/contracts/src/index.js",
      "default": "./dist/contracts/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../tools/eslint-config/lib.mjs \"src/**/*.ts\"",
    "test": "vitest run --config ./vitest.config.ts",
    "test:coverage": "vitest run --config ./vitest.config.ts --coverage --coverage.reporter=json",
    "stryker": "pnpm exec stryker run stryker.conf.mjs"
  },
  "devDependencies": {
    "@types/node": "24.12.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stynx-nyx/stynx.git",
    "directory": "packages/contracts"
  }
}
